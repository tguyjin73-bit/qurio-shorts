# Streamlit Cloud 배포 시 대시보드에 입력할 secrets 예시
# 실제 .streamlit/secrets.toml 파일은 .gitignore에 포함 → GitHub에 올리지 말 것

gemini_api_key = "AIza..."
openai_api_key = "sk-proj-..."
luma_api_key = "luma-..."
telegram_bot_token = ""
telegram_chat_id = ""

# YouTube 인증 (token.pickle → base64, client_secret.json → base64)
youtube_token_b64 = ""         # base64로 인코딩된 token.pickle 내용
youtube_client_secret_b64 = "" # base64로 인코딩된 client_secret.json 내용
